# ======================================
# GLOBAL WAR TRACKER ENVIRONMENT CONFIG
# ======================================

# --------------------------------------
# AI APIs
# --------------------------------------

# Gemini API key
# Obtain from: https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# Optional DeepSeek API key
DEEPSEEK_API_KEY=your_deepseek_api_key_here


# --------------------------------------
# ADMIN AUTHENTICATION
# --------------------------------------

# Admin email allowed to access AI controls
ADMIN_EMAIL=admin@email.com

# Secret used to sign admin sessions
# Generate a random string (32+ chars)
ADMIN_SESSION_SECRET=replace_with_random_secret


# --------------------------------------
# SMTP EMAIL SETTINGS
# --------------------------------------

# SMTP server host
SMTP_HOST=smtp.gmail.com

# SMTP port (587 for TLS)
SMTP_PORT=587

# SMTP login email
SMTP_USER=admin@email.com

# IMPORTANT:
# This must be an "App Password", not your Gmail password
# Create it here:
# https://myaccount.google.com/apppasswords
SMTP_PASS=your_gmail_app_password
